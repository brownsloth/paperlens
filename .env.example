# LLM provider (required for annotation)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Optional overrides
HUMAN_REVIEW_THRESHOLD=0.65
MAX_SPANS_PER_SEGMENT=8

# Web retrieval (Perplexity-lite)
ENABLE_WEB_SEARCH=true
MAX_SEARCH_RESULTS=3
MAX_RETRIEVED_PAGES=5
MAX_SOURCE_EXCERPT_CHARS=2000

# Optional: Tavily instead of DuckDuckGo
TAVILY_API_KEY=

# --- Public deploy (Railway + portfolio Netlify) ---
# PORT=8080
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
# CORS_ORIGINS=https://projects.tarun-ssharma.com,http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,http://127.0.0.1:5173
#
# Public demo abuse limits (all optional — defaults shown)
# PUBLIC_MAX_PDF_BYTES=15728640
# PUBLIC_MAX_PDF_PAGES=40
# PUBLIC_MAX_UPLOADS_PER_IP_HOUR=8
# PUBLIC_MAX_LLM_PER_SESSION=30
# PUBLIC_MAX_LLM_PER_IP_HOUR=80
# PUBLIC_MAX_CHAT_PER_ANNOTATION=8
# PUBLIC_MAX_QUESTION_CHARS=500
# PUBLIC_MAX_CHAT_MESSAGE_CHARS=800
# PUBLIC_MAX_CANDIDATES=8
# PUBLIC_DISABLE_BULK_ANNOTATE=true
#
# Portfolio UI: ./scripts/sync-portfolio-paperlens.sh
# API URL in serving/portfolio/config.js → window.PAPERLENS_API
